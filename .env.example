# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL
MYSQL_DATABASE=milkkart
MYSQL_USER=milkkart
MYSQL_PASSWORD=milkkart_secret
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/3

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Payment gateway (mock defaults for dev; use real Razorpay/Stripe keys in prod)
PAYMENT_GATEWAY_KEY_ID=rzp_test_key
PAYMENT_GATEWAY_SECRET=test_gateway_secret

# Cart bill engine (INR)
FREE_DELIVERY_THRESHOLD=199
DELIVERY_FEE=25
SMALL_CART_THRESHOLD=99
SMALL_CART_FEE=15
TAX_PERCENT=5
